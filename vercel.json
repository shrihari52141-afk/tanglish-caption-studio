{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "dist/server.cjs,remote-config.json"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/api/index.ts" }
  ]
}
