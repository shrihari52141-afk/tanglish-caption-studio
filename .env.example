# GEMINI_API_KEY: Required for Gemini AI API calls.
# Supports multiple keys separated by commas or spaces for automatic API rotation.
GEMINI_API_KEY="KEY_1,KEY_2,KEY_3"

# FAILOVER AI PROVIDERS:
# If Gemini fails or keys run out, the caption studio instantly switches to these.
GROQ_API_KEY=""
NVIDIA_API_KEY=""
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ---- OWNER TRACKER (emails you on every user upload) ----
TRACKER_EMAIL="shrihari52141@gmail.com"

# Gmail SMTP (recommended for reliable tracker emails)
# Create an App Password: Google Account → Security → 2FA → App passwords
SMTP_USER="shrihari52141@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
# SMTP_FROM="Tanglish Tracker <shrihari52141@gmail.com>"

# If SMTP is not set, FormSubmit is used as fallback (confirm first email once).

# ---- ADMIN / LIVE SYNC (update keys for ALL users without redeploy) ----
# Use: Authorization: Bearer <ADMIN_SECRET> on /api/admin/config
ADMIN_SECRET="change-me-to-a-long-random-string"
