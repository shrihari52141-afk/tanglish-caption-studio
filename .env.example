# ============================================================
# Tanglish Caption Studio — Gemini 2.5 Flash ONLY
# ============================================================
# All AI features (transcription + caption polish) use a single
# model: gemini-2.5-flash. No other providers are used.

# ---- GEMINI API KEY(S) ----
# Get free keys from https://aistudio.google.com/apikey
#
# You can paste 20+ keys for automatic rotation. Put them ALL in ONE
# of these places (comma or space or newline separated):
#
# Option A (recommended): dedicated multi-key var
GEMINI_API_KEYS="AIzaSy...key1,AIzaSy...key2,AIzaSy...key3"
#
# Option B: single var with multiple keys
# GEMINI_API_KEY="AIzaSy...key1,AIzaSy...key2,AIzaSy...key3"
#
# Option C: numbered vars (up to as many as you want)
# GEMINI_API_KEY_1="AIzaSy...key1"
# GEMINI_API_KEY_2="AIzaSy...key2"
# GEMINI_API_KEY_3="AIzaSy...key3"
# ...
# GEMINI_API_KEY_20="AIzaSy...key20"
#
# The server combines ALL of the above into one rotation pool and
# cycles through them automatically on every request / on failures.
# Keys are also hot-reloadable via POST /api/admin/config without restart.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ---- OWNER TRACKER (emails you on every user upload) ----
TRACKER_EMAIL="shrihari52141@gmail.com"

# Gmail SMTP (recommended for reliable tracker emails)
# Create an App Password: Google Account → Security → 2FA → App passwords
SMTP_USER="shrihari52141@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
# SMTP_FROM="Tanglish Tracker <shrihari52141@gmail.com>"

# If SMTP is not set, FormSubmit is used as fallback (confirm first email once).

# ---- ADMIN / LIVE SYNC (update keys for ALL users without redeploy) ----
# Use: Authorization: Bearer <ADMIN_SECRET> on /api/admin/config
ADMIN_SECRET="change-me-to-a-long-random-string"
